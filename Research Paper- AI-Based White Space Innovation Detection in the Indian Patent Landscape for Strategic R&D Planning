    "# =========================================\n",
    "# PHASE 5 — COMPLETE VISUALIZATION PIPELINE\n",
    "# =========================================\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import re\n",
    "from sklearn.preprocessing import MinMaxScaler\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Load Cleaned Datasets\n",
    "# ---------------------------------------\n",
    "\n",
    "india = pd.read_csv(\"india_cleaned.csv\")\n",
    "ai = pd.read_csv(\"india_ai_from_full.csv\")\n",
    "\n",
    "# ---------------------------------------\n",
    "#  India vs AI Growth\n",
    "# ---------------------------------------\n",
    "\n",
    "total_per_year = india.groupby(\"FILING_YEAR\").size().reset_index(name=\"TOTAL_PATENTS\")\n",
    "ai_per_year = ai.groupby(\"FILING_YEAR\").size().reset_index(name=\"AI_PATENTS\")\n",
    "\n",
    "macro = total_per_year.merge(ai_per_year, on=\"FILING_YEAR\", how=\"left\")\n",
    "macro[\"AI_PATENTS\"] = macro[\"AI_PATENTS\"].fillna(0)\n",
    "macro[\"AI_SHARE_PERCENT\"] = (macro[\"AI_PATENTS\"] / macro[\"TOTAL_PATENTS\"]) * 100\n",
    "\n",
    "# ---- Plot 1: India vs AI Growth\n",
    "plt.figure()\n",
    "plt.plot(macro[\"FILING_YEAR\"], macro[\"TOTAL_PATENTS\"])\n",
    "plt.plot(macro[\"FILING_YEAR\"], macro[\"AI_PATENTS\"])\n",
    "plt.xlabel(\"Filing Year\")\n",
    "plt.ylabel(\"Number of Patents\")\n",
    "plt.title(\"India vs AI Patent Growth\")\n",
    "plt.legend([\"Total Patents\", \"AI Patents\"])\n",
    "plt.show()\n",
    "\n",
    "# ---- Plot 2: AI Share Trend\n",
    "plt.figure()\n",
    "plt.plot(macro[\"FILING_YEAR\"], macro[\"AI_SHARE_PERCENT\"])\n",
    "plt.xlabel(\"Filing Year\")\n",
    "plt.ylabel(\"AI Share (%)\")\n",
    "plt.title(\"AI Share in Indian Patent Landscape\")\n",
    "plt.show()\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Extract AI Subclasses Properly\n",
    "# ---------------------------------------\n",
    "\n",
    "def extract_g06n(cpc):\n",
    "    if pd.isna(cpc):\n",
    "        return None\n",
    "    matches = re.findall(r\"G06N\\d+/\\d+\", cpc.replace(\" \", \"\"))\n",
    "    return matches[0] if matches else None\n",
    "\n",
    "ai[\"AI_SUBCLASS\"] = ai[\"CPC_CLASSIFICATIONS\"].apply(extract_g06n)\n",
    "ai = ai.dropna(subset=[\"AI_SUBCLASS\"])\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Subclass Growth Heatmap Data\n",
    "# ---------------------------------------\n",
    "\n",
    "subclass_year = (\n",
    "    ai.groupby([\"AI_SUBCLASS\", \"FILING_YEAR\"])\n",
    "    .size()\n",
    "    .reset_index(name=\"PATENT_COUNT\")\n",
    ")\n",
    "\n",
    "pivot = subclass_year.pivot(\n",
    "    index=\"AI_SUBCLASS\",\n",
    "    columns=\"FILING_YEAR\",\n",
    "    values=\"PATENT_COUNT\"\n",
    ").fillna(0)\n",
    "\n",
    "plt.figure()\n",
    "plt.imshow(pivot.values, aspect=\"auto\")\n",
    "plt.xticks(range(len(pivot.columns)), pivot.columns, rotation=90)\n",
    "plt.yticks(range(len(pivot.index)), pivot.index)\n",
    "plt.xlabel(\"Filing Year\")\n",
    "plt.ylabel(\"AI Subclass\")\n",
    "plt.title(\"AI Subclass Growth Heatmap\")\n",
    "plt.colorbar()\n",
    "plt.show()\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Competition (HHI)\n",
    "# ---------------------------------------\n",
    "\n",
    "hhi_results = []\n",
    "\n",
    "for subclass in ai[\"AI_SUBCLASS\"].unique():\n",
    "    data = ai[ai[\"AI_SUBCLASS\"] == subclass]\n",
    "    assignee_counts = data.groupby(\"APPLICANTS\").size()\n",
    "    total = assignee_counts.sum()\n",
    "    shares = assignee_counts / total\n",
    "    hhi = (shares ** 2).sum()\n",
    "    \n",
    "    hhi_results.append({\n",
    "        \"AI_SUBCLASS\": subclass,\n",
    "        \"HHI\": hhi,\n",
    "        \"UNIQUE_ASSIGNEES\": data[\"APPLICANTS\"].nunique()\n",
    "    })\n",
    "\n",
    "competition_df = pd.DataFrame(hhi_results)\n",
    "\n",
    "plt.figure()\n",
    "plt.bar(competition_df[\"AI_SUBCLASS\"], competition_df[\"HHI\"])\n",
    "plt.xticks(rotation=90)\n",
    "plt.xlabel(\"AI Subclass\")\n",
    "plt.ylabel(\"HHI\")\n",
    "plt.title(\"Competition Intensity Across AI Subclasses\")\n",
    "plt.show()\n",
    "\n",
    "# ---------------------------------------\n",
    "# Citation + IOS Calculation\n",
    "# ---------------------------------------\n",
    "\n",
    "citation_df = (\n",
    "    ai.groupby(\"AI_SUBCLASS\")[\"CITED_BY_PATENT_COUNT\"]\n",
    "    .mean()\n",
    "    .reset_index(name=\"AVG_CITATION\")\n",
    ")\n",
    "\n",
    "# CAGR per subclass\n",
    "cagr_results = []\n",
    "\n",
    "for subclass in subclass_year[\"AI_SUBCLASS\"].unique():\n",
    "    data = subclass_year[subclass_year[\"AI_SUBCLASS\"] == subclass].sort_values(\"FILING_YEAR\")\n",

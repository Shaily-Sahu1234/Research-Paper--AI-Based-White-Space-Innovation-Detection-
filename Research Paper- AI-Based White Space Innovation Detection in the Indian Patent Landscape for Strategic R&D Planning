    "\n",
    "total_per_year = india.groupby(\"FILING_YEAR\").size().reset_index(name=\"TOTAL_PATENTS\")\n",
    "ai_per_year = ai.groupby(\"FILING_YEAR\").size().reset_index(name=\"AI_PATENTS\")\n",
    "\n",
    "macro = total_per_year.merge(ai_per_year, on=\"FILING_YEAR\", how=\"left\")\n",
    "macro[\"AI_PATENTS\"] = macro[\"AI_PATENTS\"].fillna(0)\n",
    "macro[\"AI_SHARE_PERCENT\"] = (macro[\"AI_PATENTS\"] / macro[\"TOTAL_PATENTS\"]) * 100\n",
    "\n",
    "# CAGR Function\n",
    "def calculate_cagr(df, column):\n",
    "    df = df.sort_values(\"FILING_YEAR\")\n",
    "    first_year = df[\"FILING_YEAR\"].iloc[0]\n",
    "    last_year = df[\"FILING_YEAR\"].iloc[-1]\n",
    "    first_val = df[column].iloc[0]\n",
    "    last_val = df[column].iloc[-1]\n",
    "    years = last_year - first_year\n",
    "    if first_val > 0 and years > 0:\n",
    "        return ((last_val / first_val) ** (1 / years)) - 1\n",
    "    return np.nan\n",
    "\n",
    "total_cagr = calculate_cagr(macro, \"TOTAL_PATENTS\")\n",
    "ai_cagr = calculate_cagr(macro, \"AI_PATENTS\")\n",

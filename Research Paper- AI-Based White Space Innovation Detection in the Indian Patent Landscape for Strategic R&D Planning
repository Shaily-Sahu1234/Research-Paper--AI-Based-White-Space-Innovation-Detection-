    "# =========================================\n",
    "# PHASE 3 — AI SUBCLASS WHITE SPACE ENGINE\n",
    "# =========================================\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.preprocessing import MinMaxScaler\n",
    "\n",
    "# ---------------------------------------\n",
    "# Load AI Dataset (Extracted from Full India)\n",
    "# ---------------------------------------\n",
    "\n",
    "ai = pd.read_csv(\"india_ai_from_full.csv\")\n",
    "\n",
    "print(\"AI dataset loaded:\", ai.shape)\n",
    "\n",
    "# ---------------------------------------\n",
    "# Extract AI Subclass (First 7 Characters)\n",
    "# ---------------------------------------\n",
    "\n",
    "# Take first CPC before semicolon\n",
    "ai[\"FIRST_CPC\"] = ai[\"CPC_CLASSIFICATIONS\"].astype(str).str.split(\";\").str[0].str.strip()\n",
    "\n",
    "# Extract first 7 characters (e.g., G06N 3/0)\n",
    "ai[\"AI_SUBCLASS\"] = ai[\"FIRST_CPC\"].str[:7]\n",
    "\n",
    "print(\"\\nUnique AI Subclasses Found:\")\n",
    "print(ai[\"AI_SUBCLASS\"].unique())\n",
    "\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Growth Analysis per Subclass\n",
    "# ---------------------------------------\n",
    "\n",
    "subclass_year = (\n",
    "    ai.groupby([\"AI_SUBCLASS\", \"FILING_YEAR\"])\n",
    "    .size()\n",
    "    .reset_index(name=\"PATENT_COUNT\")\n",
    ")\n",
    "\n",
    "# CAGR Calculation\n",
    "cagr_results = []\n",
    "\n",
    "for subclass in subclass_year[\"AI_SUBCLASS\"].unique():\n",
    "    \n",
    "    data = subclass_year[subclass_year[\"AI_SUBCLASS\"] == subclass].sort_values(\"FILING_YEAR\")\n",
    "    \n",
    "    if len(data) < 2:\n",
    "        continue\n",
    "    \n",
    "    first_year = data[\"FILING_YEAR\"].iloc[0]\n",
    "    last_year = data[\"FILING_YEAR\"].iloc[-1]\n",
    "    \n",
    "    first_value = data[\"PATENT_COUNT\"].iloc[0]\n",
    "    last_value = data[\"PATENT_COUNT\"].iloc[-1]\n",
    "    \n",
    "    years = last_year - first_year\n",
    "    \n",
    "    if first_value > 0 and years > 0:\n",
    "        cagr = ((last_value / first_value) ** (1 / years)) - 1\n",
    "    else:\n",
    "        cagr = np.nan\n",
    "    \n",
    "    cagr_results.append({\n",
    "        \"AI_SUBCLASS\": subclass,\n",
    "        \"CAGR\": cagr\n",
    "    })\n",
    "\n",
    "cagr_df = pd.DataFrame(cagr_results)\n",
    "\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Competition Intensity\n",
    "# ---------------------------------------\n",
    "\n",
    "competition_results = []\n",
    "\n",
    "for subclass in ai[\"AI_SUBCLASS\"].unique():\n",
    "    \n",
    "    data = ai[ai[\"AI_SUBCLASS\"] == subclass]\n",
    "    \n",
    "    assignee_counts = data.groupby(\"APPLICANTS\").size()\n",
    "    \n",
    "    total = assignee_counts.sum()\n",
    "    shares = assignee_counts / total\n",
    "    \n",
    "    hhi = (shares ** 2).sum()\n",
    "    \n",
    "    competition_results.append({\n",
    "        \"AI_SUBCLASS\": subclass,\n",
    "        \"UNIQUE_ASSIGNEES\": data[\"APPLICANTS\"].nunique(),\n",
    "        \"HHI\": hhi\n",
    "    })\n",
    "\n",
    "competition_df = pd.DataFrame(competition_results)\n",
    "\n",
    "\n",
    "# ---------------------------------------\n",
    "# Citation Intensity\n",
    "# ---------------------------------------\n",
    "\n",
    "citation_df = (\n",
    "    ai.groupby(\"AI_SUBCLASS\")[\"CITED_BY_PATENT_COUNT\"]\n",
    "    .mean()\n",
    "    .reset_index(name=\"AVG_CITATION\")\n",
    ")\n",
    "\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Commercial Strength (Family Size)\n",
    "# ---------------------------------------\n",
    "\n",
    "family_df = (\n",
    "    ai.groupby(\"AI_SUBCLASS\")[\"FAMILY_SIZE\"]\n",
    "    .mean()\n",
    "    .reset_index(name=\"AVG_FAMILY_SIZE\")\n",
    ")\n",
    "\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Merge All Metrics\n",
    "# ---------------------------------------\n",
    "\n",
    "ai_analysis = (\n",
    "    cagr_df\n",
    "    .merge(competition_df, on=\"AI_SUBCLASS\")\n",
    "    .merge(citation_df, on=\"AI_SUBCLASS\")\n",
    "    .merge(family_df, on=\"AI_SUBCLASS\")\n",
    ")\n",
    "\n",
    "ai_analysis = ai_analysis.dropna()\n",
    "\n",
    "\n",
    "# ---------------------------------------\n",
    "# Innovation Opportunity Score (IOS)\n",
    "# IOS = (Growth × Citation) / Competition\n",
    "# ---------------------------------------\n",
    "\n",
    "# Normalize metrics for stability\n",
    "scaler = MinMaxScaler()\n",
    "\n",
    "ai_analysis[\"GROWTH_NORM\"] = scaler.fit_transform(ai_analysis[[\"CAGR\"]])\n",
    "ai_analysis[\"CITATION_NORM\"] = scaler.fit_transform(ai_analysis[[\"AVG_CITATION\"]])\n",
    "\n",
    "# Competition inverse (lower HHI = better)\n",
    "ai_analysis[\"COMP_INV\"] = 1 - ai_analysis[\"HHI\"]\n",
    "ai_analysis[\"COMP_NORM\"] = scaler.fit_transform(ai_analysis[[\"COMP_INV\"]])\n",
    "\n",
    "# Final IOS\n",
    "ai_analysis[\"IOS\"] = (\n",
    "    ai_analysis[\"GROWTH_NORM\"] *\n",
    "    ai_analysis[\"CITATION_NORM\"]\n",
    ") / (ai_analysis[\"HHI\"] + 1e-6)\n",
    "\n",
    "# Rank\n",
    "ai_analysis = ai_analysis.sort_values(by=\"IOS\", ascending=False)\n",
    "ai_analysis[\"RANK\"] = range(1, len(ai_analysis) + 1)\n",
    "\n",
    "print(\"\\n=== AI SUBCLASS WHITE SPACE RANKING ===\")\n",
    "print(ai_analysis[[\n",
    "    \"AI_SUBCLASS\",\n",

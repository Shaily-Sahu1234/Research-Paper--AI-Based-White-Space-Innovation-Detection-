    "# =========================================\n",
    "# COMPLETE MACRO WHITE SPACE ENGINE\n",
    "# (CAGR + HHI + Citation + IOS in one run)\n",
    "# =========================================\n",
    "\n",
    "from sklearn.preprocessing import MinMaxScaler\n",
    "\n",
    "# Load cleaned dataset\n",
    "df = pd.read_csv(\"india_ready.csv\")\n",
    "\n",
    "# ---------------------------------------\n",
    "#  CAGR Calculation\n",
    "# ---------------------------------------\n",
    "\n",
    "ipc_year = df.groupby(['IPC_SECTION', 'FILING_YEAR']).size().reset_index(name='PATENT_COUNT')\n",
    "\n",
    "cagr_results = []\n",
    "\n",
    "for section in ipc_year['IPC_SECTION'].unique():\n",
    "    \n",
    "    section_data = ipc_year[ipc_year['IPC_SECTION'] == section].sort_values('FILING_YEAR')\n",
    "    \n",
    "    if len(section_data) < 2:\n",
    "        continue\n",
    "    \n",
    "    first_year = section_data['FILING_YEAR'].iloc[0]\n",
    "    last_year = section_data['FILING_YEAR'].iloc[-1]\n",
    "    \n",
    "    first_value = section_data['PATENT_COUNT'].iloc[0]\n",
    "    last_value = section_data['PATENT_COUNT'].iloc[-1]\n",
    "    \n",
    "    years = last_year - first_year\n",
    "    \n",
    "    if first_value > 0 and years > 0:\n",
    "        cagr = ((last_value / first_value) ** (1 / years)) - 1\n",
    "    else:\n",
    "        cagr = np.nan\n",
    "    \n",
    "    cagr_results.append({\n",
    "        'IPC_SECTION': section,\n",
    "        'CAGR': cagr\n",
    "    })\n",
    "\n",
    "cagr_df = pd.DataFrame(cagr_results)\n",
    "\n",
    "# ---------------------------------------\n",
    "# Competition (HHI)\n",
    "# ---------------------------------------\n",
    "\n",
    "hhi_results = []\n",
    "\n",
    "for section in df['IPC_SECTION'].dropna().unique():\n",
    "    \n",
    "    section_data = df[df['IPC_SECTION'] == section]\n",
    "    \n",
    "    assignee_counts = section_data.groupby('APPLICANTS').size()\n",
    "    \n",
    "    total = assignee_counts.sum()\n",
    "    shares = assignee_counts / total\n",
    "    \n",
    "    hhi = (shares ** 2).sum()\n",
    "    \n",
    "    hhi_results.append({\n",
    "        'IPC_SECTION': section,\n",
    "        'HHI': hhi\n",
    "    })\n",
    "\n",
    "hhi_df = pd.DataFrame(hhi_results)\n",
    "\n",
    "# ---------------------------------------\n",
    "# Average Citation\n",
    "# ---------------------------------------\n",
    "\n",
    "citation_df = (\n",
    "    df.groupby('IPC_SECTION')['CITATION_INTENSITY']\n",
    "    .mean()\n",
    "    .reset_index(name='AVG_CITATION')\n",
    ")\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Merge All Metrics\n",
    "# ---------------------------------------\n",
    "\n",
    "macro_df = (\n",
    "    cagr_df\n",
    "    .merge(hhi_df, on='IPC_SECTION', how='left')\n",
    "    .merge(citation_df, on='IPC_SECTION', how='left')\n",
    ")\n",
    "\n",
    "macro_df = macro_df.dropna()\n",
    "\n",
    "# ---------------------------------------\n",
    "# Normalize Metrics\n",
    "# ---------------------------------------\n",
    "\n",
    "scaler = MinMaxScaler()\n",
    "\n",
    "macro_df['CAGR_NORM'] = scaler.fit_transform(macro_df[['CAGR']])\n",
    "macro_df['CITATION_NORM'] = scaler.fit_transform(macro_df[['AVG_CITATION']])\n",
    "\n",
    "# Invert competition (lower HHI = better opportunity)\n",
    "macro_df['COMP_INV'] = 1 - macro_df['HHI']\n",
    "macro_df['COMP_NORM'] = scaler.fit_transform(macro_df[['COMP_INV']])\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Innovation Opportunity Score\n",
    "# ---------------------------------------\n",
    "\n",
    "macro_df['IOS'] = (\n",
    "    macro_df['CAGR_NORM'] *\n",
    "    macro_df['CITATION_NORM'] *\n",
    "    macro_df['COMP_NORM']\n",
    ")\n",
    "\n",
    "macro_df = macro_df.sort_values(by='IOS', ascending=False)\n",
    "macro_df['RANK'] = range(1, len(macro_df) + 1)\n",
    "\n",
    "print(\"\\n=== MACRO WHITE SPACE RANKING ===\")\n",
    "print(macro_df[['IPC_SECTION', 'CAGR', 'AVG_CITATION', 'HHI', 'IOS', 'RANK']])\n",
    "\n",
    "# Save result\n",
    "macro_df.to_csv(\"india_macro_white_space_results.csv\", index=False)\n",
    "\n",
    "print(\"\\nWhite space ranking completed successfully.\")"
   ]

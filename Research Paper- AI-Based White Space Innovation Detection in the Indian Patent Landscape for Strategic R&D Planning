    "    \"UNIQUE_ASSIGNEES\",\n",
    "    \"HHI\",\n",
    "    \"IOS\",\n",
    "    \"RANK\"\n",
    "]])\n",
    "\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Identify White Spaces vs Saturation\n",
    "# ---------------------------------------\n",
    "\n",
    "top_threshold = ai_analysis[\"IOS\"].quantile(0.75)\n",
    "bottom_threshold = ai_analysis[\"IOS\"].quantile(0.25)\n",
    "\n",
    "ai_analysis[\"DOMAIN_TYPE\"] = np.where(\n",
    "    ai_analysis[\"IOS\"] >= top_threshold,\n",
    "    \"Emerging White Space\",\n",
    "    np.where(\n",
    "        ai_analysis[\"IOS\"] <= bottom_threshold,\n",
    "        \"Saturated Domain\",\n",
    "        \"Moderate Competition\"\n",
    "    )\n",
    ")\n",
    "\n",
    "print(\"\\n=== Domain Classification ===\")\n",
    "print(ai_analysis[[\"AI_SUBCLASS\", \"DOMAIN_TYPE\"]])\n",

    "# =========================================\n",
    "# PHASE 2 — MACRO INDIA CONTEXT\n",
    "# =========================================\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Load Datasets\n",
    "# ---------------------------------------\n",
    "\n",
    "india = pd.read_csv(\"india_cleaned.csv\")\n",
    "ai = pd.read_csv(\"india_ai_from_full.csv\")\n",
    "\n",
    "print(\"Datasets loaded.\")\n",
    "print(\"India shape:\", india.shape)\n",
    "print(\"AI shape:\", ai.shape)\n",
    "\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Total Patents Per Year\n",
    "# ---------------------------------------\n",
    "\n",
    "total_per_year = (\n",
    "    india.groupby(\"FILING_YEAR\")\n",
    "    .size()\n",
    "    .reset_index(name=\"TOTAL_PATENTS\")\n",
    ")\n",
    "\n",
    "# ---------------------------------------\n",
    "#  AI Patents Per Year\n",
    "# ---------------------------------------\n",
    "\n",
    "ai_per_year = (\n",
    "    ai.groupby(\"FILING_YEAR\")\n",
    "    .size()\n",
    "    .reset_index(name=\"AI_PATENTS\")\n",
    ")\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Merge and Compute AI Share\n",
    "# ---------------------------------------\n",
    "\n",
    "macro_trend = total_per_year.merge(\n",
    "    ai_per_year,\n",
    "    on=\"FILING_YEAR\",\n",
    "    how=\"left\"\n",
    ")\n",
    "\n",
    "macro_trend[\"AI_PATENTS\"] = macro_trend[\"AI_PATENTS\"].fillna(0)\n",
    "\n",
    "macro_trend[\"AI_SHARE_PERCENT\"] = (\n",
    "    macro_trend[\"AI_PATENTS\"] / macro_trend[\"TOTAL_PATENTS\"]\n",
    ") * 100\n",
    "\n",
    "print(\"\\n=== Macro Trend Table ===\")\n",
    "print(macro_trend)\n",
    "\n",
    "\n",
    "# ---------------------------------------\n",
    "#  CAGR Calculation Function\n",
    "# ---------------------------------------\n",
    "\n",
    "def calculate_cagr(df, value_column):\n",
    "    \n",
    "    df = df.sort_values(\"FILING_YEAR\")\n",
    "    \n",
    "    first_year = df[\"FILING_YEAR\"].iloc[0]\n",
    "    last_year = df[\"FILING_YEAR\"].iloc[-1]\n",
    "    \n",
    "    first_value = df[value_column].iloc[0]\n",
    "    last_value = df[value_column].iloc[-1]\n",
    "    \n",
    "    years = last_year - first_year\n",
    "    \n",
    "    if first_value > 0 and years > 0:\n",
    "        cagr = ((last_value / first_value) ** (1 / years)) - 1\n",
    "    else:\n",
    "        cagr = np.nan\n",
    "    \n",
    "    return cagr\n",
    "\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Compute CAGR\n",
    "# ---------------------------------------\n",
    "\n",
    "total_cagr = calculate_cagr(macro_trend, \"TOTAL_PATENTS\")\n",
    "ai_cagr = calculate_cagr(macro_trend, \"AI_PATENTS\")\n",
    "\n",
    "print(\"\\n=== CAGR Results ===\")\n",
    "print(\"Total Patent CAGR:\", round(total_cagr * 100, 2), \"%\")\n",
    "print(\"AI Patent CAGR:\", round(ai_cagr * 100, 2), \"%\")\n",
    "\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Acceleration Conclusion\n",
    "# ---------------------------------------\n",
    "\n",
    "if ai_cagr > total_cagr:\n",
    "    print(\"\\nConclusion: AI is accelerating faster than the national innovation baseline.\")\n",
    "elif ai_cagr < total_cagr:\n",
    "    print(\"\\nConclusion: AI growth is slower than the national innovation baseline.\")\n",
    "else:\n",
    "    print(\"\\nConclusion: AI growth matches the national innovation baseline.\")\n",
    "\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Save Results\n",
    "# ---------------------------------------\n",
    "\n",
    "macro_trend.to_csv(\"india_macro_ai_trend.csv\", index=False)\n",
    "\n",
    "print(\"\\nPHASE 2 COMPLETED SUCCESSFULLY.\")"

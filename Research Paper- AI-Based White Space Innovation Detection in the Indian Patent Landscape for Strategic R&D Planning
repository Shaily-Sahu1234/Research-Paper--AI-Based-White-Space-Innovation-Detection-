    "# =========================================\n",
    "# ROBUST AI TECHNOLOGY THEME MAPPING\n",
    "# =========================================\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import re\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Load AI dataset (extracted from full India)\n",
    "# ---------------------------------------\n",
    "\n",
    "ai = pd.read_csv(\"india_ai_from_full.csv\")\n",
    "\n",
    "print(\"AI dataset loaded:\", ai.shape)\n",
    "\n",
    "# Ensure required columns exist\n",
    "required_cols = [\"CPC_CLASSIFICATIONS\", \"FILING_YEAR\"]\n",
    "for col in required_cols:\n",
    "    if col not in ai.columns:\n",
    "        raise ValueError(f\"Missing required column: {col}\")\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Extract ALL G06N subclasses properly\n",
    "# ---------------------------------------\n",
    "\n",
    "def extract_all_g06n(cpc_string):\n",
    "    if pd.isna(cpc_string):\n",
    "        return []\n",
    "    \n",
    "    # Remove spaces for consistency\n",
    "    cpc_string = cpc_string.replace(\" \", \"\")\n",
    "    \n",
    "    # Find patterns like G06N3/08, G06N5/02, G06N7/00\n",
    "    matches = re.findall(r\"G06N\\d+/\\d+\", cpc_string)\n",
    "    \n",
    "    return matches\n",
    "\n",
    "# Apply extraction\n",
    "ai[\"AI_SUBCLASSES\"] = ai[\"CPC_CLASSIFICATIONS\"].apply(extract_all_g06n)\n",
    "\n",
    "# Explode multiple subclasses into separate rows\n",
    "ai_exploded = ai.explode(\"AI_SUBCLASSES\")\n",
    "\n",
    "# Remove rows without G06N subclass\n",
    "ai_exploded = ai_exploded.dropna(subset=[\"AI_SUBCLASSES\"])\n",
    "\n",
    "print(\"Unique AI subclasses detected:\")\n",
    "print(ai_exploded[\"AI_SUBCLASSES\"].unique())\n",
    "\n",
    "# ---------------------------------------\n",
    "#  Create AI Theme Mapping (Robust)\n",
    "# ---------------------------------------\n",
    "\n",
    "def map_theme(subclass):\n",
    "    if subclass.startswith(\"G06N3\"):\n",
    "        return \"Neural Networks / Deep Learning\"\n",
    "    elif subclass.startswith(\"G06N5\"):\n",
    "        return \"Expert Systems / Rule-Based AI\"\n",
    "    elif subclass.startswith(\"G06N7\"):\n",
    "        return \"Probabilistic Models / Bayesian AI\"\n",
    "    elif subclass.startswith(\"G06N20\"):\n",
    "        return \"Machine Learning (General)\"\n",
    "    elif subclass.startswith(\"G06N10\"):\n",
    "        return \"Fuzzy Logic\"\n",
    "    else:\n",
    "        return \"Other AI Methods\"\n",
    "\n",
    "ai_exploded[\"AI_THEME\"] = ai_exploded[\"AI_SUBCLASSES\"].apply(map_theme)\n",
    "\n",
    "print(\"\\nDetected AI Themes:\")\n",
    "print(ai_exploded[\"AI_THEME\"].unique())\n",
    "\n",
    "# ---------------------------------------\n",
    "# Growth Analysis Per Theme\n",
    "# ---------------------------------------\n",
    "\n",
    "theme_growth = (\n",
    "    ai_exploded.groupby([\"AI_THEME\", \"FILING_YEAR\"])\n",
    "    .size()\n",
    "    .reset_index(name=\"PATENT_COUNT\")\n",
    ")\n",
    "\n",
    "print(\"\\n=== AI Theme Growth Sample ===\")\n",
    "print(theme_growth.head())\n",
    "\n",
    "# ---------------------------------------\n",
    "#  CAGR Per Theme\n",
    "# ---------------------------------------\n",
    "\n",
    "cagr_results = []\n",
    "\n",
    "for theme in theme_growth[\"AI_THEME\"].unique():\n",
    "    \n",
    "    data = theme_growth[theme_growth[\"AI_THEME\"] == theme].sort_values(\"FILING_YEAR\")\n",
    "    \n",
    "    if len(data) < 2:\n",
    "        continue\n",
    "    \n",
    "    first_year = data[\"FILING_YEAR\"].iloc[0]\n",
    "    last_year = data[\"FILING_YEAR\"].iloc[-1]\n",
    "    \n",
    "    first_value = data[\"PATENT_COUNT\"].iloc[0]\n",
    "    last_value = data[\"PATENT_COUNT\"].iloc[-1]\n",
    "    \n",
    "    years = last_year - first_year\n",
    "    \n",
    "    if first_value > 0 and years > 0:\n",
    "        cagr = ((last_value / first_value) ** (1 / years)) - 1\n",
    "    else:\n",
    "        cagr = np.nan\n",
    "    \n",
    "    cagr_results.append({\n",
    "        \"AI_THEME\": theme,\n",
    "        \"CAGR\": cagr\n",
    "    })\n",
    "\n",
    "cagr_df = pd.DataFrame(cagr_results)\n",
    "\n",
    "print(\"\\n=== AI Theme CAGR ===\")\n",
    "print(cagr_df)\n",
    "\n",
    "print(\"\\nAI THEME MAPPING COMPLETED SUCCESSFULLY.\")"

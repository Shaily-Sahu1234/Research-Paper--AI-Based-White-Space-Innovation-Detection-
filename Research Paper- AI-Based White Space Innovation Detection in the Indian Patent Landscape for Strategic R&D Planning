    "# =========================================\n",
    "# PHASE 2 – STEP 4: COMPETITION INTENSITY\n",
    "# IPC Section Level Analysis\n",
    "# =========================================\n",
    "\n",
    "df = india_ready.copy()\n",
    "\n",
    "# Ensure applicants column exists\n",
    "if 'APPLICANTS' not in df.columns:\n",
    "    raise ValueError(\"APPLICANTS column not found.\")\n",
    "\n",
    "# Remove missing applicants\n",
    "df = df.dropna(subset=['APPLICANTS'])\n",
    "\n",
    "# ------------------------------------------\n",
    "# Unique Assignees per IPC Section\n",
    "# ------------------------------------------\n",
    "\n",
    "unique_assignees = (\n",
    "    df.groupby('IPC_SECTION')['APPLICANTS']\n",
    "    .nunique()\n",
    "    .reset_index(name='UNIQUE_ASSIGNEES')\n",
    ")\n",
    "\n",
    "# ------------------------------------------\n",
    "#  Patent Count per IPC Section\n",
    "# ------------------------------------------\n",
    "\n",
    "section_patent_counts = (\n",
    "    df.groupby('IPC_SECTION')\n",
    "    .size()\n",
    "    .reset_index(name='TOTAL_PATENTS')\n",
    ")\n",
    "\n",
    "# ------------------------------------------\n",
    "#  Calculate HHI per IPC Section\n",
    "# ------------------------------------------\n",
    "\n",
    "hhi_results = []\n",
    "\n",
    "for section in df['IPC_SECTION'].dropna().unique():\n",
    "    \n",
    "    section_data = df[df['IPC_SECTION'] == section]\n",
    "    \n",
    "    # Patent count per assignee in this section\n",
    "    assignee_counts = section_data.groupby('APPLICANTS').size()\n",
    "    \n",
    "    total_patents = assignee_counts.sum()\n",
    "    \n",
    "    # Market share per assignee\n",
    "    market_shares = assignee_counts / total_patents\n",
    "    \n",
    "    # HHI calculation\n",
    "    hhi = (market_shares ** 2).sum()\n",
    "    \n",
    "    hhi_results.append({\n",
    "        'IPC_SECTION': section,\n",
    "        'HHI': hhi\n",
    "    })\n",
    "\n",
    "hhi_df = pd.DataFrame(hhi_results)\n",
    "\n",
    "# ------------------------------------------\n",
    "#  Merge All Competition Metrics\n",
    "# ------------------------------------------\n",
    "\n",
    "competition_df = (\n",
    "    section_patent_counts\n",
    "    .merge(unique_assignees, on='IPC_SECTION', how='left')\n",
    "    .merge(hhi_df, on='IPC_SECTION', how='left')\n",
    ")\n",
    "\n",
    "# ------------------------------------------\n",
    "#  Classify Market Structure\n",
    "# ------------------------------------------\n",
    "\n",
    "def classify_hhi(hhi):\n",
    "    if hhi < 0.10:\n",
    "        return \"Fragmented (Low Concentration)\"\n",
    "    elif hhi < 0.18:\n",
    "        return \"Moderate Concentration\"\n",
    "    else:\n",
    "        return \"Highly Concentrated\"\n",
    "\n",
    "competition_df['MARKET_STRUCTURE'] = competition_df['HHI'].apply(classify_hhi)\n",
    "\n",
    "# Sort by HHI descending\n",
    "competition_df = competition_df.sort_values(by='HHI', ascending=False)\n",
    "\n",
    "print(\"\\nCompetition Intensity by IPC Section:\")\n",
    "print(competition_df)\n",
    "\n",
    "# ------------------------------------------\n",
    "#  Save Results\n",
    "# ------------------------------------------\n",
    "\n",
    "competition_df.to_csv(\"india_ipc_competition_intensity.csv\", index=False)\n",
    "\n",
    "print(\"\\nCompetition intensity analysis completed and saved.\")"
   ]

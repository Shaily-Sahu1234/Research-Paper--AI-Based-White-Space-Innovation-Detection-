    "\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import os\n",
    "import re\n",
    "from sklearn.preprocessing import MinMaxScaler\n",
    "\n",
    "print(\"Libraries Loaded\")\n",
    "\n",
    "\n",
    "\n",
    "folder_path = os.getcwd()\n",
    "\n",
    "files = [f for f in os.listdir(folder_path) if f.endswith(\".csv\")]\n",
    "\n",
    "print(\"Detected CSV files:\")\n",
    "print(files)\n",
    "\n",
    "dataframes = {}\n",
    "\n",
    "for file in files:\n",
    "    try:\n",
    "        df = pd.read_csv(file, engine=\"python\", on_bad_lines=\"skip\")\n",
    "        dataframes[file] = df\n",
    "        print(f\"Loaded {file}  shape={df.shape}\")\n",
    "    except:\n",
    "        print(f\"Could not load {file}\")\n",
    "\n",
    "\n",
    "\n",
    "india = None\n",
    "\n",
    "for name, df in dataframes.items():\n",
    "    if \"CPC\" in str(df.columns):\n",
    "        india = df\n",
    "        print(\"Using dataset:\", name)\n",
    "        break\n",
    "\n",
    "if india is None:\n",
    "    raise Exception(\"No suitable patent dataset found\")\n",
    "\n",
    "\n",
    "def clean_columns(df):\n",
    "\n",
    "    df.columns = (\n",
    "        df.columns\n",
    "        .str.strip()\n",
    "        .str.replace('\"','', regex=False)\n",
    "        .str.replace(\"'\",\"\", regex=False)\n",
    "        .str.replace(\" \",\"_\", regex=False)\n",
    "        .str.upper()\n",
    "    )\n",
    "\n",
    "    return df\n",
    "\n",
    "india = clean_columns(india)\n",
    "\n",
    "print(\"Columns cleaned\")\n",
    "\n",
    "\n",
    "india[\"APPLICATION_DATE\"] = pd.to_datetime(india[\"APPLICATION_DATE\"], errors=\"coerce\")\n",
    "\n",
    "india[\"FILING_YEAR\"] = india[\"APPLICATION_DATE\"].dt.year\n",
    "\n",
    "india = india.dropna(subset=[\"FILING_YEAR\"])\n",
    "\n",
    "print(\"Filing year created\")\n",
    "\n",
    "\n",
    "india = india.dropna(subset=[\"CPC_CLASSIFICATIONS\"])\n",
    "\n",
    "print(\"Records after CPC filtering:\", len(india))\n",
    "\n",
    "\n",
    "if \"SIMPLE_FAMILY_MEMBERS\" in india.columns:\n",
    "\n",
    "    india = india.drop_duplicates(subset=\"SIMPLE_FAMILY_MEMBERS\")\n",
    "\n",
    "print(\"Duplicates removed\")\n",
    "\n",
    "\n",
    "\n",
    "india[\"CPC_CLASSIFICATIONS\"] = india[\"CPC_CLASSIFICATIONS\"].astype(str)\n",
    "\n",
    "ai_patents = india[india[\"CPC_CLASSIFICATIONS\"].str.contains(\"G06N\", na=False)].copy()\n",
    "\n",
    "print(\"AI patents detected:\", len(ai_patents))\n",
    "\n",
    "\n",
    "\n",
    "total_per_year = india.groupby(\"FILING_YEAR\").size().reset_index(name=\"TOTAL_PATENTS\")\n",
    "\n",
    "ai_per_year = ai_patents.groupby(\"FILING_YEAR\").size().reset_index(name=\"AI_PATENTS\")\n",
    "\n",
    "macro = total_per_year.merge(ai_per_year, on=\"FILING_YEAR\", how=\"left\")\n",
    "\n",
    "macro[\"AI_PATENTS\"] = macro[\"AI_PATENTS\"].fillna(0)\n",
    "\n",
    "macro[\"AI_SHARE_PERCENT\"] = (macro[\"AI_PATENTS\"] / macro[\"TOTAL_PATENTS\"]) * 100\n",
    "\n",
    "macro.head()\n",
    "\n",
    "\n",
    "\n",
    "def calculate_cagr(series, years):\n",
    "\n",
    "    first = series.iloc[0]\n",
    "    last = series.iloc[-1]\n",
    "\n",
    "    if first > 0 and years > 0:\n",
    "        return (last / first) ** (1/years) - 1\n",
    "\n",
    "    return np.nan\n",
    "\n",
    "years = macro[\"FILING_YEAR\"].max() - macro[\"FILING_YEAR\"].min()\n",
    "\n",
    "total_cagr = calculate_cagr(macro[\"TOTAL_PATENTS\"], years)\n",
    "\n",
    "ai_nonzero = macro[macro[\"AI_PATENTS\"] > 0]\n",
    "\n",
    "if len(ai_nonzero) >= 2:\n",
    "\n",
    "    years_ai = ai_nonzero[\"FILING_YEAR\"].iloc[-1] - ai_nonzero[\"FILING_YEAR\"].iloc[0]\n",
    "\n",
    "    ai_cagr = calculate_cagr(ai_nonzero[\"AI_PATENTS\"], years_ai)\n",
    "\n",
    "else:\n",
    "\n",
    "    ai_cagr = np.nan\n",
    "\n",
    "print(\"Total Patent CAGR:\", round(total_cagr*100,2), \"%\")\n",
    "print(\"AI Patent CAGR:\", round(ai_cagr*100,2), \"%\")\n",
    "\n",
    "\n",
    "\n",
    "def extract_subclass(cpc):\n",
    "\n",
    "    if pd.isna(cpc):\n",
    "        return None\n",
    "\n",
    "    matches = re.findall(r\"G06N\\d+/\\d+\", cpc.replace(\" \",\"\"))\n",
    "\n",
    "    if matches:\n",
    "        return matches[0]\n",
    "\n",
    "    return None\n",
    "\n",
    "ai_patents[\"AI_SUBCLASS\"] = ai_patents[\"CPC_CLASSIFICATIONS\"].apply(extract_subclass)\n",
    "\n",
    "ai_patents = ai_patents.dropna(subset=[\"AI_SUBCLASS\"])\n",
    "\n",
    "print(\"AI subclasses detected:\", ai_patents[\"AI_SUBCLASS\"].nunique())\n",
    "\n",
    "\n",
    "\n",
    "subclass_year = (\n",
    "    ai_patents.groupby([\"AI_SUBCLASS\",\"FILING_YEAR\"])\n",
    "    .size()\n",
    "    .reset_index(name=\"PATENT_COUNT\")\n",
    ")\n",
    "\n",
    "subclass_year.head()\n",
    "\n",
    "\n",
    "\n",
    "competition = []\n",
    "\n",
    "for subclass in ai_patents[\"AI_SUBCLASS\"].unique():\n",
    "\n",
    "    data = ai_patents[ai_patents[\"AI_SUBCLASS\"] == subclass]\n",
    "\n",
    "    assignee_counts = data.groupby(\"APPLICANTS\").size()\n",
    "\n",
    "    shares = assignee_counts / assignee_counts.sum()\n",
    "\n",
    "    hhi = (shares**2).sum()\n",
    "\n",
    "    competition.append({\n",
    "        \"AI_SUBCLASS\": subclass,\n",
    "        \"HHI\": hhi,\n",
    "        \"UNIQUE_ASSIGNEES\": data[\"APPLICANTS\"].nunique()\n",
    "    })\n",
    "\n",
    "competition_df = pd.DataFrame(competition)\n",
    "\n",
    "competition_df.head()\n",
    "\n",
    "\n",
    "citation_df = (\n",
    "    ai_patents.groupby(\"AI_SUBCLASS\")[\"CITED_BY_PATENT_COUNT\"]\n",
    "    .mean()\n",
    "    .reset_index(name=\"AVG_CITATION\")\n",
    ")\n",
    "\n",
    "citation_df.head()\n",
    "\n",
    "\n",
    "\n",
    "growth = []\n",
    "\n",
    "for subclass in subclass_year[\"AI_SUBCLASS\"].unique():\n",
    "\n",
    "    data = subclass_year[subclass_year[\"AI_SUBCLASS\"] == subclass].sort_values(\"FILING_YEAR\")\n",
    "\n",
    "    if len(data) < 2:\n",
    "        continue\n",
    "\n",
    "    first_year = data[\"FILING_YEAR\"].iloc[0]\n",
    "    last_year = data[\"FILING_YEAR\"].iloc[-1]\n",
    "\n",
    "    first_val = data[\"PATENT_COUNT\"].iloc[0]\n",
    "    last_val = data[\"PATENT_COUNT\"].iloc[-1]\n",
    "\n",
    "    years = last_year - first_year\n",
    "\n",
    "    if first_val > 0 and years > 0:\n",
    "\n",
    "        cagr = (last_val / first_val) ** (1/years) - 1\n",
    "\n",
    "    else:\n",
    "\n",
    "        cagr = np.nan\n",
    "\n",
    "    growth.append({\n",
    "        \"AI_SUBCLASS\": subclass,\n",
    "        \"CAGR\": cagr\n",
    "    })\n",
    "\n",
    "growth_df = pd.DataFrame(growth)\n",
    "\n",
    "growth_df.head()\n",
    "\n",
    "\n",
    "\n",
    "analysis = (\n",
    "    growth_df\n",
    "    .merge(competition_df, on=\"AI_SUBCLASS\")\n",
    "    .merge(citation_df, on=\"AI_SUBCLASS\")\n",
    ")\n",
    "\n",
    "analysis = analysis.dropna()\n",
    "\n",
    "scaler = MinMaxScaler()\n",
    "\n",
    "analysis[\"GROWTH_NORM\"] = scaler.fit_transform(analysis[[\"CAGR\"]])\n",
    "\n",
    "analysis[\"CITATION_NORM\"] = scaler.fit_transform(analysis[[\"AVG_CITATION\"]])\n",
    "\n",
    "analysis[\"IOS\"] = (\n",
    "    analysis[\"GROWTH_NORM\"] *\n",
    "    analysis[\"CITATION_NORM\"]\n",
    ") / (analysis[\"HHI\"] + 1e-6)\n",
    "\n",
    "analysis = analysis.sort_values(by=\"IOS\", ascending=False)\n",
    "\n",
    "analysis[\"RANK\"] = range(1, len(analysis)+1)\n",
    "\n",
    "analysis.head()\n",
    "\n",
    "\n",
    "\n",
    "plt.figure()\n",
    "\n",
    "plt.plot(macro[\"FILING_YEAR\"], macro[\"TOTAL_PATENTS\"])\n",
    "plt.plot(macro[\"FILING_YEAR\"], macro[\"AI_PATENTS\"])\n",
    "\n",
    "plt.xlabel(\"Year\")\n",
    "plt.ylabel(\"Patent Count\")\n",
    "plt.title(\"India vs AI Patent Growth\")\n",
    "\n",
    "plt.legend([\"Total Patents\",\"AI Patents\"])\n",
    "\n",
    "plt.show()\n",
    "\n",
    "\n",
    "\n",
    "plt.figure()\n",
    "\n",
    "plt.plot(macro[\"FILING_YEAR\"], macro[\"AI_SHARE_PERCENT\"])\n",
    "\n",
    "plt.xlabel(\"Year\")\n",
    "plt.ylabel(\"AI Share (%)\")\n",
    "plt.title(\"AI Share in Indian Patent Landscape\")\n",
    "\n",
    "plt.show()\n",
    "\n",
    "\n",
    "\n",
    "plt.figure()\n",
    "\n",
    "plt.bar(analysis[\"AI_SUBCLASS\"], analysis[\"HHI\"])\n",
    "\n",
    "plt.xticks(rotation=90)\n",
    "\n",
    "plt.xlabel(\"AI Subclass\")\n",
    "plt.ylabel(\"HHI\")\n",
    "\n",
    "plt.title(\"Competition Intensity Across AI Subclasses\")\n",
    "\n",
    "plt.show()\n",
    "\n",
    "\n",
    "\n",
    "plt.figure()\n",
    "\n",
    "plt.bar(analysis[\"AI_SUBCLASS\"], analysis[\"IOS\"])\n",
    "\n",
    "plt.xticks(rotation=90)\n",
    "\n",
    "plt.xlabel(\"AI Subclass\")\n",
    "plt.ylabel(\"Innovation Opportunity Score\")\n",
    "\n",
    "plt.title(\"AI White Space Ranking\")\n",
    "\n",
    "plt.show()\n",
    "\n",
    "print(\"PROJECT PIPELINE COMPLETED SUCCESSFULLY\")"
   ]
